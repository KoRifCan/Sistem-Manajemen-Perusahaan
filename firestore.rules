rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    function isHr() {
      return request.auth != null && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'hr'];
    }

    match /users/{userId} {
      allow read, write: if request.auth != null && (request.auth.uid == userId || isAdmin());
    }

    match /employees/{employeeId} {
      allow read: if request.auth != null;
      allow write: if isHr();
    }

    match /departments/{id} { allow read: if request.auth != null; allow write: if isHr(); }
    match /positions/{id} { allow read: if request.auth != null; allow write: if isHr(); }
    match /position_grades/{id} { allow read: if request.auth != null; allow write: if isHr(); }

    match /attendance/{id} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    match /leaves/{id} { allow read, write: if request.auth != null; }
    match /leave_balances/{id} { allow read, write: if request.auth != null; }
    match /leave_types/{id} { allow read: if request.auth != null; allow write: if isHr(); }

    match /approvals/{id} { allow read, write: if request.auth != null; }

    match /payroll_periods/{id} { allow read: if isHr(); allow write: if isAdmin(); }
    match /payslips/{id} { allow read: if request.auth != null; allow write: if isHr(); }
    match /salary_components/{id} { allow read: if isHr(); allow write: if isAdmin(); }
    match /tax_records/{id} { allow read: if isHr(); allow write: if isAdmin(); }
    match /bpjs_records/{id} { allow read: if request.auth != null; allow write: if isHr(); }
    match /loans/{id} { allow read, write: if request.auth != null; }
    match /thr_records/{id} { allow read: if request.auth != null; allow write: if isHr(); }

    match /assets/{id} { allow read, write: if request.auth != null; }
    match /asset_categories/{id} { allow read: if request.auth != null; allow write: if isAdmin(); }
    match /asset_loans/{id} { allow read, write: if request.auth != null; }

    match /documents/{id} { allow read, write: if request.auth != null; }
    match /document_categories/{id} { allow read, write: if request.auth != null; }

    match /notifications/{id} { allow read, write: if request.auth != null; }

    match /company/{id} { allow read: if request.auth != null; allow write: if isAdmin(); }

    match /audit_logs/{id} { allow read: if isAdmin(); allow write: if request.auth != null; }
    match /roles/{id} { allow read: if request.auth != null; allow write: if isAdmin(); }
    match /help_tickets/{id} { allow read, write: if request.auth != null; }
    match /overtimes/{id} { allow read, write: if request.auth != null; }
    match /business_trips/{id} { allow read, write: if request.auth != null; }
    match /permissions/{id} { allow read, write: if request.auth != null; }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
